// backend/routes/politicianRoutes.js

const express = require('express');
const path = require('path');
const multer = require('multer');
const { protect, politicianOnly } = require('../../middleware/authMiddleware');
const {
    getPoliticianProfile,
    createOrUpdatePoliticianProfile,
    uploadProfilePhoto,
    createPromise,
    getMyPromises,
} = require('../../controllers/politician/politicianController');

const router = express.Router();

// All routes here must be protected and restricted to the 'politician' role
router.use(protect, politicianOnly);

// --- Profile Routes ---
router.route('/profile')
    .get(getPoliticianProfile)           // GET /api/politician/profile
    .post(createOrUpdatePoliticianProfile); // POST /api/politician/profile (create or update)

const storage = multer.diskStorage({
    destination: function (req, file, cb) {
        cb(null, path.join(__dirname, '../../uploads/profilePhotos'));
    },
    filename: function (req, file, cb) {
        const uniqueSuffix = Date.now() + '-' + Math.round(Math.random() * 1e9);
        const ext = path.extname(file.originalname);
        cb(null, uniqueSuffix + ext);
    }
});

const fileFilter = (req, file, cb) => {
    const allowed = ['image/jpeg', 'image/png', 'image/jpg', 'image/webp'];
    if (allowed.includes(file.mimetype)) cb(null, true);
    else cb(new Error('Only image files are allowed'));
};

const upload = multer({ storage, fileFilter, limits: { fileSize: 5 * 1024 * 1024 } });

router.post('/profile/photo', upload.single('photo'), uploadProfilePhoto);

// --- Promise Routes ---
// Separate storage for promise photos
const promiseStorage = multer.diskStorage({
    destination: function (req, file, cb) {
        cb(null, path.join(__dirname, '../../uploads/promisePhotos'));
    },
    filename: function (req, file, cb) {
        const uniqueSuffix = Date.now() + '-' + Math.round(Math.random() * 1e9);
        const ext = path.extname(file.originalname);
        cb(null, uniqueSuffix + ext);
    }
});
const promiseUpload = multer({ 
    storage: promiseStorage, 
    fileFilter, 
    limits: { fileSize: 5 * 1024 * 1024 } 
});

router.route('/promises')
    .get(getMyPromises)                 // GET /api/politician/promises
    .post(promiseUpload.single('photo'), createPromise); // POST with optional photo

// Additional routes for promise editing/deleting can be added later

module.exports = router;