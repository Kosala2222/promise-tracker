import React, { useState, useEffect, useContext, useCallback } from 'react';
import { View, Text, ScrollView, Alert, ActivityIndicator, TouchableOpacity, StyleSheet, Image, Dimensions } from 'react-native';
import { AuthContext } from '../../../context/AuthContext';
import axios from 'axios';
import * as ImagePicker from 'expo-image-picker';
import CitizenBottomBar from '../../../components/CitizenBottomBar';
import { API_BASE_URL, API_BASE_ROOT } from '../../../config/env';

const API_CITIZEN = `${API_BASE_URL}/citizen`; 
const { width } = Dimensions.get('window');
const INTEREST_OPTIONS = ['Education', 'Health', 'Infrastructure', 'Finance', 'Security', 'Environment', 'Jobs', 'Housing'];

const CitizenProfileScreen = () => {
    const { user } = useContext(AuthContext); 
    const [profile, setProfile] = useState(null);
    const [loading, setLoading] = useState(true);
    const [isSaving, setIsSaving] = useState(false);
    const [selectedInterests, setSelectedInterests] = useState([]);
    const [imageUri, setImageUri] = useState(null);
    const [followedPoliticiansDetails, setFollowedPoliticiansDetails] = useState([]);

    const fetchProfile = useCallback(async () => {
        if (!user || user.role !== 'citizen') {
            setLoading(false);
            return;
        }
        try {
            const response = await axios.get(`${API_CITIZEN}/profile`); 
            setProfile(response.data);
            setSelectedInterests(response.data.interests || []);
            if (response.data.profilePhotoUrl) {
                setImageUri(`${API_BASE_ROOT}${response.data.profilePhotoUrl}`);
            } else {
                setImageUri(null);
            }
        } catch (error) {
            Alert.alert('Error', error.response?.data?.message || 'Failed to fetch profile.');
        } finally {
            setLoading(false);
        }
    }, [user]);

    useEffect(() => {
        fetchProfile();
    }, [fetchProfile]);

    useEffect(() => {
        const fetchFollowedDetails = async () => {
            if (!profile || !Array.isArray(profile.followedPoliticians) || profile.followedPoliticians.length === 0) {
                setFollowedPoliticiansDetails([]);
                return;
            }
            try {
                const pResponse = await axios.get(`${API_CITIZEN}/politicians`);
                const followedIds = profile.followedPoliticians.map(id => id.toString());
                const filtered = (pResponse.data || []).filter(p => followedIds.includes(p._id.toString()));
                setFollowedPoliticiansDetails(filtered);
            } catch (error) {
                // silent fail to avoid interrupting profile UX
            }
        };
        fetchFollowedDetails();
    }, [profile]);

    const pickImage = async () => {
        const { status } = await ImagePicker.requestMediaLibraryPermissionsAsync();
        if (status !== 'granted') {
            Alert.alert('Permission required', 'Permission to access media library is required.');
            return;
        }
        const result = await ImagePicker.launchImageLibraryAsync({
            mediaTypes: ImagePicker.MediaTypeOptions.Images,
            quality: 0.7,
        });
        if (!result.canceled && result.assets && result.assets.length > 0) {
            setImageUri(result.assets[0].uri);
        }
    };

    const uploadPhoto = async () => {
        if (!imageUri) {
            Alert.alert('No image', 'Please select an image first.');
            return;
        }
        try {
            const formData = new FormData();
            const filename = imageUri.split('/').pop() || `photo.jpg`;
            const ext = filename.split('.').pop();
            const type = ext ? `image/${ext}` : 'image/jpeg';
            formData.append('photo', { uri: imageUri, name: filename, type });

            const response = await axios.post(`${API_CITIZEN}/profile/photo`, formData, {
                headers: {
                    'Content-Type': 'multipart/form-data',
                },
            });
            const { profilePhotoUrl, profile: updated } = response.data;
            if (profilePhotoUrl) {
                setImageUri(`${API_BASE_ROOT}${profilePhotoUrl}`);
            }
            if (updated) setProfile(updated);
            Alert.alert('Success', 'Profile photo updated.');
        } catch (error) {
            Alert.alert('Error', error.response?.data?.message || 'Failed to upload photo.');
        }
    };

    const handleInterestToggle = (interest) => {
        setSelectedInterests(prev => 
            prev.includes(interest) 
                ? prev.filter(i => i !== interest) 
                : [...prev, interest]
        );
    };

    const handleSave = async () => {
        setIsSaving(true);
        try {
            const payload = { interests: selectedInterests };
            const response = await axios.post(`${API_CITIZEN}/profile`, payload);
            setProfile(response.data.profile);
            Alert.alert('Success', response.data.message);
        } catch (error) {
            Alert.alert('Error', error.response?.data?.message || 'Failed to save profile.');
        } finally {
            setIsSaving(false);
        }
    };

    if (loading) {
        return (
            <View style={[styles.container, styles.center]}>
                <ActivityIndicator size="large" color="#1D4ED8" />
                <Text style={styles.loadingText}>Loading Profile...</Text>
            </View>
        );
    }
    
    return (
        <View style={{ flex: 1, backgroundColor: '#E0E7FF' }}>
        <ScrollView style={styles.scrollContainer} contentContainerStyle={styles.scrollContent}> 
            <Text style={styles.header}>Your Profile</Text>

            <View style={styles.profileHeader}>
                <View style={styles.avatarContainer}>
                    {imageUri ? (
                        <Image source={{ uri: imageUri }} style={styles.avatar} />
                    ) : (
                        <View style={[styles.avatar, styles.avatarPlaceholder]}>
                            <Text style={styles.avatarPlaceholderText}>No Photo</Text>
                        </View>
                    )}
                </View>
                <Text style={styles.name}>{user?.username || 'Citizen'}</Text>
                <Text style={styles.email}>{user?.email || '-'}</Text>
                <View style={styles.roleBadge}>
                    <Text style={styles.roleBadgeText}>{(user?.role || 'citizen').toUpperCase()}</Text>
                </View>
                <View style={styles.avatarButtonsRow}>
                    <TouchableOpacity style={[styles.uploadButton, styles.chooseButton]} onPress={pickImage}>
                        <Text style={styles.uploadButtonText}>Choose Photo</Text>
                    </TouchableOpacity>
                    <TouchableOpacity style={[styles.uploadButton, styles.savePhotoButton]} onPress={uploadPhoto}>
                        <Text style={styles.uploadButtonText}>Upload</Text>
                    </TouchableOpacity>
                </View>
            </View>

            <Text style={styles.sectionTitle}>Preferences</Text>
            <View style={styles.card}>
                <Text style={[styles.smallLabel]}>Select Your Key Interests</Text>
                <View style={styles.interestsContainer}>
                    {INTEREST_OPTIONS.map(interest => (
                        <TouchableOpacity
                            key={interest}
                            style={[
                                styles.interestTag,
                                selectedInterests.includes(interest) ? styles.interestTagSelected : styles.interestTagDefault
                            ]}
                            onPress={() => handleInterestToggle(interest)}
                        >
                            <Text style={styles.interestTagText}>{interest}</Text>
                        </TouchableOpacity>
                    ))}
                </View>
            </View>

            <Text style={styles.sectionTitle}>Following</Text>
            <View style={styles.card}>
                <Text style={styles.followingText}>
                    You are currently following 
                    <Text style={styles.followingCount}> {profile?.followedPoliticians?.length || 0} </Text> 
                    politician(s).
                </Text>
            </View>

            {followedPoliticiansDetails.length > 0 && (
                <View style={styles.card}>
                    <Text style={styles.smallLabel}>Followed Politicians</Text>
                    <View>
                        {followedPoliticiansDetails.map(p => {
                            const photoUrl = p?.profile?.profilePhotoUrl ? `${API_BASE_ROOT}${p.profile.profilePhotoUrl}` : null;
                            return (
                                <View key={p._id} style={styles.fpCard}>
                                    {photoUrl ? (
                                        <Image source={{ uri: photoUrl }} style={styles.fpAvatar} />
                                    ) : (
                                        <View style={[styles.fpAvatar, styles.avatarPlaceholder]} />
                                    )}
                                    <View style={styles.fpCardContent}>
                                        <Text style={styles.fpName}>{p.username}{p.profile?.isVerified ? ' ✅' : ''}</Text>
                                        <Text style={styles.fpParty}>{p.profile?.party} - {p.profile?.position}</Text>
                                    </View>
                                </View>
                            );
                        })}
                    </View>
                </View>
            )}

            <TouchableOpacity
                style={[
                    styles.saveButton,
                    isSaving ? styles.saveButtonLoading : styles.saveButtonDefault
                ]}
                onPress={handleSave}
                disabled={isSaving}
            >
                {isSaving ? (
                    <ActivityIndicator color="#fff" />
                ) : (
                    <Text style={styles.saveButtonText}>Save Preferences</Text>
                )}
            </TouchableOpacity>

            <View style={styles.spacer}></View>
        </ScrollView>
        <CitizenBottomBar />
        </View>
    );
};

const styles = StyleSheet.create({
    // Loading
    container: { flex: 1, backgroundColor: '#E0E7FF' },
    center: { flex: 1, justifyContent: 'center', alignItems: 'center' },
    loadingText: { marginTop: 10, color: '#374151' },

    // Scroll
    scrollContainer: { flex: 1, backgroundColor: '#E0E7FF' },
    scrollContent: { paddingHorizontal: 20, paddingTop: 40, paddingBottom: 50 },

    // Header
    header: { fontSize: 32, fontWeight: '900', color: '#4C1D95', textAlign: 'center', marginBottom: 24, textTransform: 'uppercase', letterSpacing: 1.5 },

    // Profile header card
    profileHeader: { alignItems: 'center', backgroundColor: 'white', borderRadius: 20, paddingVertical: 26, paddingHorizontal: 16, shadowColor: '#000', shadowOffset: { width: 0, height: 6 }, shadowOpacity: 0.1, shadowRadius: 10, elevation: 6, borderWidth: 1, borderColor: '#E5E7EB', marginBottom: 28 },
    avatarContainer: { alignItems: 'center', marginBottom: 20 },
    avatar: { width: Math.min(width * 0.55, 190), height: Math.min(width * 0.55, 190), borderRadius: 100, borderWidth: 4, borderColor: '#5B21B6', shadowColor: '#4C1D95', shadowOpacity: 0.3, shadowRadius: 10, backgroundColor: '#F3F4F6' },
    avatarPlaceholder: { alignItems: 'center', justifyContent: 'center' },
    avatarPlaceholderText: { color: '#6B7280', fontSize: 14 },
    name: { fontSize: 22, fontWeight: '800', color: '#1E293B', marginBottom: 4 },
    email: { color: '#475569', fontSize: 14 },
    roleBadge: { marginTop: 10, backgroundColor: '#DDD6FE', paddingHorizontal: 14, paddingVertical: 6, borderRadius: 50 },
    roleBadgeText: { color: '#4C1D95', fontWeight: '700', fontSize: 12, letterSpacing: 0.6 },
    avatarButtonsRow: { flexDirection: 'row', marginTop: 16, justifyContent: 'center', gap: 12 },
    uploadButton: { paddingHorizontal: 18, paddingVertical: 10, borderRadius: 10, shadowColor: '#000', shadowOpacity: 0.1, shadowRadius: 3, elevation: 3 },
    chooseButton: { backgroundColor: '#6366F1' },
    savePhotoButton: { backgroundColor: '#4C1D95' },
    uploadButtonText: { color: 'white', fontWeight: '700', fontSize: 14 },

    // Sections and cards
    sectionTitle: { fontSize: 20, fontWeight: '800', color: '#1E3A8A', marginTop: 8, marginBottom: 10 },
    smallLabel: { fontSize: 13, color: '#475569', marginBottom: 8 },
    card: { backgroundColor: 'white', borderRadius: 16, padding: 18, shadowColor: '#000', shadowOffset: { width: 0, height: 4 }, shadowOpacity: 0.1, shadowRadius: 8, elevation: 5, borderWidth: 1, borderColor: '#E5E7EB', marginBottom: 20 },

    // Interests
    interestsContainer: { flexDirection: 'row', flexWrap: 'wrap', marginBottom: 6 },
    interestTag: { paddingHorizontal: 15, paddingVertical: 8, borderRadius: 20, margin: 5, borderWidth: 1 },
    interestTagDefault: { backgroundColor: '#E5E7EB', borderColor: '#D1D5DB' },
    interestTagSelected: { backgroundColor: '#DBEAFE', borderColor: '#3B82F6' },
    interestTagText: { fontSize: 14, color: '#1F2937', fontWeight: '500' },

    // Save button
    saveButton: { marginTop: 10, height: 52, flexDirection: 'row', alignItems: 'center', justifyContent: 'center', borderRadius: 14, shadowColor: '#000', shadowOffset: { width: 0, height: 4 }, shadowOpacity: 0.15, shadowRadius: 6, elevation: 5 },
    saveButtonDefault: { backgroundColor: '#4C1D95' },
    saveButtonLoading: { backgroundColor: '#818CF8' },
    saveButtonText: { fontSize: 18, fontWeight: '800', color: 'white', letterSpacing: 0.6, textTransform: 'uppercase' },

    // Following text
    followingText: { fontSize: 16, color: '#047857' },
    followingCount: { fontWeight: 'bold', fontSize: 18 },

    // Followed politicians list
    fpCard: { flexDirection: 'row', backgroundColor: 'white', borderRadius: 12, padding: 12, marginBottom: 12, alignItems: 'center', shadowColor: '#000', shadowOffset: { width: 0, height: 2 }, shadowOpacity: 0.06, shadowRadius: 3, elevation: 2 },
    fpCardContent: { flex: 1, marginLeft: 12 },
    fpAvatar: { width: Math.min(width * 0.18, 56), height: Math.min(width * 0.18, 56), borderRadius: 9999, backgroundColor: '#E5E7EB' },
    fpName: { fontSize: 16, fontWeight: 'bold', color: '#1F2937' },
    fpParty: { fontSize: 13, color: '#4B5563', marginTop: 3 },

    // Spacer
    spacer: { height: 90 },
});

export default CitizenProfileScreen;
