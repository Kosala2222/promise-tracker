// backend/middleware/authMiddleware.js
const jwt = require('jsonwebtoken');
const User = require('../models/User');

// --- 1. Protect routes (ensures user is logged in and token is valid) ---
// This middleware must be run first on any route that requires a logged-in user.
const protect = async (req, res, next) => {
    let token;

    // Check for authorization header (Bearer token)
    if (req.headers.authorization && req.headers.authorization.startsWith('Bearer')) {
        try {
            // Extract the token (second part of "Bearer token")
            token = req.headers.authorization.split(' ')[1];

            // Verify token using the secret key
            const decoded = jwt.verify(token, process.env.JWT_SECRET);

            // Fetch the user from the database using the ID stored in the token payload
            // We select everything EXCEPT the password for security
            req.user = await User.findById(decoded.id).select('-password');
            
            // Attach the user's role directly from the token payload to req.role
            req.role = decoded.role;

            next();
        } catch (error) {
            console.error('Token verification failed:', error);
            // If the token is invalid or expired
            return res.status(401).json({ message: 'Not authorized, token failed.' });
        }
    }

    if (!token) {
        // If no token is provided in the request header
        return res.status(401).json({ message: 'Not authorized, no token.' });
    }
};

// --- 2. Role-based access control functions ---
// These MUST be used AFTER the 'protect' middleware.

// Restricts access to only users with the 'politician' role
const politicianOnly = (req, res, next) => {
    if (req.role === 'politician') {
        next(); 
    } else {
        res.status(403).json({ message: 'Not authorized as a politician.' });
    }
};

// Restricts access to only users with the 'citizen' role
const citizen = (req, res, next) => {
    if (req.role === 'citizen') {
        next();
    } else {
        res.status(403).json({ message: 'Not authorized as a citizen.' });
    }
};


// Restricts access to only users with the 'admin' role
const adminOnly = (req, res, next) => {
    if (req.role === 'admin') {
        next();
    } else {
        res.status(403).json({ message: 'Not authorized as an admin.' });
    }
};

// Restricts access to users with 'ngo' or 'journalist' roles (for verification/reporting tasks)
const ngoOrJournalistOnly = (req, res, next) => {
    if (req.role === 'ngo' || req.role === 'journalist') {
        next(); 
    } else {
        res.status(403).json({ message: 'Not authorized for this oversight role.' });
    }
};

// Restricts access to only users with the 'ngo' role
const ngoOnly = (req, res, next) => {
    if (req.role === 'ngo') {
        next();
    } else {
        res.status(403).json({ message: 'Not authorized as an NGO.' });
    }
};

// Restricts access to only users with the 'journalist' role
const journalistOnly = (req, res, next) => {
    if (req.role === 'journalist') {
        next();
    } else {
        res.status(403).json({ message: 'Not authorized as a journalist.' });
    }
};

module.exports = { protect, politicianOnly, adminOnly, ngoOrJournalistOnly, citizen, journalistOnly, ngoOnly };
